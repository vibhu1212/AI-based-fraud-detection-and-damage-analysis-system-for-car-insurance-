# Application
APP_NAME=InsurAI
APP_VERSION=1.0.0
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Database
DATABASE_URL=sqlite:///./insurai.db
# DATABASE_URL=postgresql://user:password@localhost:5432/insurai

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET_KEY=insurai-dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Storage
STORAGE_PATH=./storage

# AI/ML
OPENAI_API_KEY=your-openai-api-key-here
OCR_ENGINE=tesseract
DETECTION_MODEL_PATH=./models/yolov8.pt


# Surveyor Assignment
# Comma-separated list of senior surveyor user IDs for RED risk claim assignment
SENIOR_SURVEYOR_IDS=
