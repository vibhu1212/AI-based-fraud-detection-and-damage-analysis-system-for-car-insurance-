#!/usr/bin/env bash
# ============================================================
# InsurAI — Start All Services (macOS)
# Double-click this file in Finder to start!
# Or run: chmod +x start.command && ./start.command
# ============================================================

# cd to the script's directory (needed for double-click from Finder)
cd "$(dirname "$0")"

# Run the main start script
exec ./start.sh
